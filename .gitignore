# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep the safe template so new clones know which vars to set
!.env.example

# Local state snapshots / container backups — these tarballs contain LIVE
# secrets (config.yaml with bot tokens, .env with API keys, auth.json, WhatsApp
# session creds). NEVER push to any remote. Keep them on local/secure storage.
.backups/
**/wa-sessions/
**/creds.json

# Nested node_modules (root /node_modules already covered above)
node_modules/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python bytecode / cache (build artifacts)
__pycache__/
*.pyc
*.pyo

# Local engine image + volume backups (large binaries, never commit)
docker-image-backups/
.recon-telegram/

*.backup

# Session-handoff / scratch docs may carry LIVE secrets (keys, passwords) —
# never track. (Any already in history must be purged + rotated separately.)
Docs/SESSION-HANDOFF*.md
**/SESSION-HANDOFF*.md
Docs/**/*secret*
Docs/**/*SECRET*

# D5 admin volume backups (dev)
.volume-backups/
